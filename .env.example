# Futrumi GraphQL endpoint. Defaults to production if unset.
FUTRUMI_GRAPHQL_URL=https://futrumi-prod-w7u56.ondigitalocean.app/graphql

# HTTP port the MCP server listens on.
PORT=8080

# info | debug
LOG_LEVEL=info

# Public deeplink base used in tool output. Falls back to https://futrumi.cz
FUTRUMI_DEEPLINK_BASE=https://futrumi.cz

# How many GraphQL candidates search_recommendations fetches before local semantic ranking.
SEMANTIC_CANDIDATE_LIMIT=120
