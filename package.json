{
  "name": "futrumi-mcp",
  "version": "0.1.0",
  "private": true,
  "description": "MCP server exposing Futrumi restaurant recommendations to Claude, ChatGPT, and Codex.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "typecheck": "tsc --noEmit",
    "inspect": "npx --yes @modelcontextprotocol/inspector"
  },
  "dependencies": {
    "@hono/node-server": "1.19.4",
    "@modelcontextprotocol/sdk": "1.29.0",
    "graphql": "16.11.0",
    "graphql-request": "7.4.0",
    "hono": "4.12.23",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/node": "22.10.7",
    "tsx": "4.19.2",
    "typescript": "5.7.3"
  }
}
